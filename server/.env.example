# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/skillsync

# JWT
JWT_SECRET=your_jwt_secret_key_here_minimum_32_characters
JWT_EXPIRES_IN=7d

# Google OAuth2 (JWT Verification Only - No Redirect Needed)
# Steps to get these values:
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 credentials (Web application)
# 3. Add Authorized JavaScript origins: http://localhost:5173
# 4. Copy Client ID and Client Secret below
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# AI/ML Services
GEMINI_API_KEY=your_gemini_api_key_here

# Cloudinary (Image Upload)
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email Service (Brevo)
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=noreply@skillsync.ai
BREVO_SENDER_NAME=SkillSync AI

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Redis (Optional - for session management)
REDIS_URL=redis://localhost:6379

# Socket.io (for real-time notifications)
SOCKET_URL=http://localhost:5000
